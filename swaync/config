{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "ignore-gtk-theme": true,
  "positionX": "right",
  "positionY": "top",
  "control-center-margin-top": 10,
  "control-center-margin-bottom": 10,
  "control-center-margin-right": 10,
  "notification-body-image-height": 100,
  "notification-body-image-width": 200,
  "timeout": 10,
  "timeout-low": 5,
  "timeout-critical": 0,
  "fit-to-screen": false,
  "control-center-width": 500,
  "control-center-height": 1035,
  "notification-window-width": 500,
  "keyboard-shortcuts": true,
  "image-visibility": "when-available",
  "transition-time": 200,
  "hide-on-clear": false,
  "hide-on-action": false,
  "script-fail-notify": true,
  "text-empty": "No Notification",
  "scripts": {
    "sound-script": {
      "exec": "paplay ~/.config/swaync/notification.ogg",
      "app-name": ".*"
    }
  },
  "widgets": ["title", "buttons-grid", "mpris"],
  "widget-config": {
    "title": {
      "text": "Notification Center",
      "clear-all-button": false
    },
    "mpris": {
      "blacklist": ["playerctl"],
      "autohide": false,
      "show-album-art": "always",
      "loop-carousel": false
    },
    "volume": {
      "label": "󰕾"
    },
    "backlight": {
      "label": "󰃟"
    },
    "buttons-grid": {
      "actions": [
        {
          "label": "󰐥",
          "command": "swaynag -c ~/.config/swaynag/config -t default -m 'Do you really want to shutdown?' -b 'Yes' 'systemctl poweroff'"
        },
        {
          "label": "󰜉",
          "command": "swaynag -c ~/.config/swaynag/config -t default -m 'Do you really want to reboot?' -b 'Yes' 'systemctl reboot'"
        },
        {
          "label": "󰌾",
          "command": "playerctl pause || swaylock -C ~/.config/swaylock/config"
        },
        {
          "label": "󰍃",
          "command": "swaynag -t default -m 'Do you really want to exit sway? This will end your Wayland session.' -B 'Yes' 'swaymsg exit'"
        },
        {
          "label": "󰆴",
          "command": "swaync-client -C"
        },
        {
          "label": "󰕾",
          "command": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
          "type": "toggle"
        },
        {
          "label": "󰍬",
          "command": "pactl set-source-mute @DEFAULT_SOURCE@ toggle",
          "type": "toggle"
        },
        {
          "label": "󰖩",
          "command": "nm-connection-editor"
        },
        {
          "label": "󰂯",
          "command": "blueman-manager"
        },
        {
          "label": "",
          "command": "kooha"
        }
      ]
    }
  }
}
